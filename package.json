{
  "name": "gold-trading-research-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "tsc --noEmit --project tsconfig.lint.json",
    "check:data": "node scripts/check-site-data.mjs",
    "test:sources": ".venv-research/bin/python scripts/test_data_sources.py",
    "update:data": ".venv-research/bin/python research/gold_research_pipeline.py --json",
    "update:site": "npm run update:data && npm run check:data && npm run build",
    "verify": "npm run check:data && npm run lint && npm run build"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
